# Database (get from Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Supabase (get from Supabase → Settings → API → API Keys)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Google Cloud Vision (optional — for GSTIN OCR detection on invoice uploads)
GOOGLE_CLOUD_VISION_API_KEY=

# App
ENVIRONMENT=development
