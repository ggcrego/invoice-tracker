# ===== Backend (apps/api/.env) =====

# Database (get from Supabase → Settings → Database)
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# Google Cloud Vision
GOOGLE_CLOUD_VISION_API_KEY=AIza...

# App
ENVIRONMENT=development

# ===== Frontend (apps/web/.env) =====

VITE_SUPABASE_URL=https://[PROJECT_REF].supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_BASE_URL=http://localhost:8000/api
VITE_SLACK_WORKSPACE_ID=T0123456789
